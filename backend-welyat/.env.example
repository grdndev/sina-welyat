# ========================================
# GENERAL CONFIGURATION
# ========================================
NODE_ENV=development
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# ========================================
# POSTGRESQL CONFIGURATION (Sequelize)
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=welyat_v0_dev
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DIALECT=postgres

# ========================================
# AUTHENTICATION
# ========================================
JWT_SECRET=your_super_secret_jwt_key_welyat
JWT_EXPIRES_IN=7d

# ========================================
# STRIPE CONFIGURATION
# ========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Security Cap (USD per hour)
MAX_CHARGE_PER_HOUR=19.99

# ========================================
# TWILIO CONFIGURATION
# ========================================
TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# BUSINESS LOGIC
# ========================================
# Default Business Mode (NORMAL|SMART|SHIELD|CRITICAL)
DEFAULT_BUSINESS_MODE=NORMAL

# External Payout Threshold (USD)
EXTERNAL_PAYOUT_THRESHOLD=10.00

CORS_ALLOW_ORIGINS=http://localhost:5173
