{
    "name": "welyat-backend-v0",
    "version": "0.1.0",
    "description": "WELYAT V0 - Smart Interactive Network Audio Backend",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "migrate": "sequelize-cli db:migrate",
        "migrate:undo": "sequelize-cli db:migrate:undo",
        "seed": "sequelize-cli db:seed:all",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix",
        "format": "prettier --write \"src/**/*.js\""
    },
    "keywords": [
        "listening",
        "platform",
        "billing",
        "twilio",
        "stripe"
    ],
    "author": "GRDN Dev",
    "license": "UNLICENSED",
    "private": true,
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cors": "^2.8.6",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.3.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "node-cron": "^4.2.1",
        "pg": "^8.11.3",
        "pg-hstore": "^2.3.4",
        "resend": "^6.12.2",
        "sequelize": "^6.35.0",
        "stripe": "^14.5.0",
        "twilio": "^4.19.0",
        "uuid": "^9.0.1",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "eslint": "^8.55.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "sequelize-cli": "^6.6.2",
        "supertest": "^6.3.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
